sub roman_value(ch)
    if ch == "I"
        return 1
    end
    if ch == "V"
        return 5
    end
    if ch == "X"
        return 10
    end
    if ch == "L"
        return 50
    end
    if ch == "C"
        return 100
    end
    if ch == "D"
        return 500
    end
    return 1000
end

sub parse_roman(s)
    total = 0
    i = 0
    while i < len(s)
        v = roman_value(s[i])
        if i + 1 < len(s) and roman_value(s[i + 1]) > v
            total = total - v
        else
            total = total + v
        end
        i = i + 1
    end
    return total
end

sub to_minimal(n)
    values = [1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1]
    symbols = ["M", "CM", "D", "CD", "C", "XC", "L", "XL", "X", "IX", "V", "IV", "I"]
    result = ""
    remaining = n
    i = 0
    while i < len(values)
        val = values[i]
        sym = symbols[i]
        while remaining >= val
            result = result + sym
            remaining = remaining - val
        end
        i = i + 1
    end
    return result
end

total_saved = 0
k = 0
while k < len(numerals)
    original = numerals[k]
    value = parse_roman(original)
    minimal = to_minimal(value)
    total_saved = total_saved + (len(original) - len(minimal))
    k = k + 1
end

print total_saved
